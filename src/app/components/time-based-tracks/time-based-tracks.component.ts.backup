import { Component, OnInit, OnDestroy, Input, Output, EventEmitter, ViewChild, ElementRef, ChangeDetectorRef, AfterViewInit } from '@angular/core';
import { CommonModule } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { HttpClient } from '@angular/common/http';
import { BaseWidgetComponent } from '../../basewidget/basewidget.component';
import { WellLogWidget } from '@int/geotoolkit/welllog/widgets/WellLogWidget';
import { LogTrack } from '@int/geotoolkit/welllog/LogTrack';
import { LogCurve } from '@int/geotoolkit/welllog/LogCurve';
import { LogData as GeoLogData } from '@int/geotoolkit/welllog/data/LogData';
import { TrackType } from '@int/geotoolkit/welllog/TrackType';
import { IndexType } from '@int/geotoolkit/welllog/IndexType';
import { CssStyle } from '@int/geotoolkit/css/CssStyle';
import { TimeBasedLogService } from './time-based-log.service';
import { TimeBasedThemeService } from './time-based-theme.service'; 

export interface ITimeWellboreObject {
  objectId: string;
  objectName: string;
  wellId: string;
  wellboreId: string;
  indexType: string;
  indexCurve: string;
  isDepth: boolean;
  isGrowing: boolean;
  startIndex: string;
  endIndex: string;
  objectInfo: ITimeMnemonicInfo[];
}

export interface ITimeMnemonicInfo {
  mnemonicId: string;
  mnemonic: string;
  description: string;
  unit: string;
  data: any[];
  min: number;
  max: number;
}

export interface ITimeTrackCurve {
  mnemonicId: string;
  mnemonic: string;
  LogId: string;
  data: any[];
  min: number;
  max: number;
  unit: string;
  autoScale: boolean;
  isDepth: boolean;
}

export interface ITimeTrack {
  trackName: string;
  trackTitle: string;
  isIndex: boolean;
  isDepth: boolean;
  curves: ITimeTrackCurve[];
}

export interface ILogDataQueryParameter {
  wellUid: string;
  logUid: string;
  wellboreUid: string;
  logName: string;
  indexType: string;
  indexCurve: string;
  startIndex: any;
  endIndex: any;
  isGrowing: boolean;
  mnemonicList: string;
}

export interface LogData {
  mnemonicList: string;
  data: string[];
}

@Component({
  selector: 'app-time-based-tracks',
  standalone: true,
  imports: [CommonModule, FormsModule, BaseWidgetComponent],
  providers: [TimeBasedLogService, TimeBasedThemeService],
  templateUrl: './time-based-tracks.component.html',
  styleUrls: ['./time-based-tracks.component.css']
})
export class TimeBasedTracksComponent implements OnInit, OnDestroy, AfterViewInit {
  @ViewChild(BaseWidgetComponent) widgetComponent!: BaseWidgetComponent;

  @Input() wellId: string = '';
  @Input() wellboreId: string = '';
  @Input() listOfTracks: ITimeTrack[] = [];
  @Input() selectedScale: number = 0;
  @Input() isDarkTheme: boolean = false;
  @Input() selectedHour: number = 24;

  @Output() scaleChange = new EventEmitter<number>();
  @Output() themeChange = new EventEmitter<boolean>();
  @Output() headersLoaded = new EventEmitter<ITimeWellboreObject[]>();

  // Core properties
  wellLogWidget!: WellLogWidget;
  subscriptions: any[] = [];
  showLoading: boolean = false;
  isLiveTracking: boolean = false;
  isFirstTimeLoading: boolean = true;

  // Time-specific properties
  wellboreObjects: ITimeWellboreObject[] = [];
  indexCurveTime: Date[] = [];
  indexCurveTimeDepthForShowMarker: number[] = [];
  lastselectedDate: Date = new Date();
  livePollingInterval: any = null;

  // Theme properties
  theamFlage: boolean = false;

  constructor(
    private http: HttpClient,
    private timeBasedLogService: TimeBasedLogService,
    private timeBasedThemeService: TimeBasedThemeService,
    private cdr: ChangeDetectorRef
  ) {}

  ngOnInit(): void {
    console.log('🎯 TimeBasedTracksComponent initialized');
    console.log('🎯 Inputs:', {
      wellId: this.wellId,
      wellboreId: this.wellboreId,
      trackCount: this.listOfTracks.length,
      selectedScale: this.selectedScale,
      isDarkTheme: this.isDarkTheme,
      selectedHour: this.selectedHour
    });
    
    // Fetch log headers first
    this.fetchLogHeaders();
  }

  private fetchLogHeaders(): void {
    if (!this.wellId || !this.wellboreId) {
      console.error('❌ Well ID and Wellbore ID are required');
      return;
    }

    console.log(`📋 Fetching log headers for well: ${this.wellId}, wellbore: ${this.wellboreId}`);
    this.showLoading = true;

    this.timeBasedLogService.getTimeLogHeaders(this.wellId, this.wellboreId).subscribe(
      (headers: ITimeWellboreObject[]) => {
        console.log('✅ Time-based log headers loaded:', headers);
        this.wellboreObjects = headers;
        this.showLoading = false;
        
        // Emit headers loaded event
        this.headersLoaded.emit(headers);
        
        // Initialize widget after headers are loaded and view is ready
        if (this.widgetComponent) {
          this.initializeWidget();
        } else {
          console.warn('⚠️ Widget component not ready yet, will retry...');
          // Retry after a short delay
          setTimeout(() => {
            if (this.widgetComponent) {
              this.initializeWidget();
            } else {
              console.error('❌ Widget component still not available after retry');
            }
          }, 100);
        }
      },
      (error) => {
        console.error('❌ Error fetching time-based log headers:', error);
        this.showLoading = false;
      }
    );
  }

  /**
   * Called when well or wellbore changes
   */
  loadWellData(wellId: string, wellboreId: string): void {
    this.wellId = wellId;
    this.wellboreId = wellboreId;
    
    // Clean up existing widget
    this.cleanup();
    
    // Fetch new headers
    this.fetchLogHeaders();
  }

  ngOnDestroy(): void {
    this.cleanup();
  }
  
  ngAfterViewInit(): void {
    console.log('🎯 TimeBasedTracksComponent view initialized');
    // Don't initialize widget here - wait for headers to be loaded first
    // Widget initialization will be called after headers are fetched
  }

  private cleanup(): void {
    this.subscriptions.forEach(sub => sub.unsubscribe());
    this.stopLivePolling();
    if (this.wellLogWidget) {
      // WellLogWidget doesn't have destroy method, use dispose instead
      try {
        this.wellLogWidget.dispose();
      } catch (error) {
        console.warn('⚠️ Error disposing widget:', error);
      }
    }
  }

  private initializeWidget(): void {
    if (!this.widgetComponent || !this.widgetComponent.Canvas) {
      console.error('❌ Widget component or canvas not found');
      return;
    }

    try {
      console.log('🎯 Creating time-based WellLogWidget...');
      
      // Create widget using time-based service
      this.wellLogWidget = this.timeBasedLogService.createWellLogWidget(this.widgetComponent.Canvas.nativeElement);
      
      // Assign widget to BaseWidgetComponent
      this.widgetComponent.Widget = this.wellLogWidget;
      console.log('✅ Widget assigned to BaseWidgetComponent');

      // Apply initial theme
      this.timeBasedThemeService.applyGeoToolkitTheme(this.wellLogWidget, this.isDarkTheme);

      // Create tracks and load data
      this.createTimeBasedTracks();
      this.loadTimeBasedData();

    } catch (error) {
      console.error('❌ Error initializing time-based widget:', error);
    }
  }

  private createTimeBasedTracks(): void {
    console.log('🎯 Creating time-based tracks...');

    if (!this.listOfTracks || this.listOfTracks.length === 0) {
      console.warn('⚠️ No tracks configured for time-based display');
      return;
    }

    // Create index track first
    this.createTimeBasedIndexTrack();

    // Create data tracks
    this.listOfTracks.forEach((trackInfo, index) => {
      if (!trackInfo.isIndex) {
        this.createTimeBasedDataTrack(trackInfo, index);
      }
    });

    console.log('✅ Time-based tracks created successfully');
  }

  private createTimeBasedIndexTrack(): void {
    try {
      console.log('🎯 Creating time-based index track...');

      // Create index track using TrackType
      const indexTrack = this.wellLogWidget.addTrack(TrackType.IndexTrack);
      indexTrack.setName('Time Index');
      indexTrack.setWidth(80);

      console.log('✅ Time-based index track created');

    } catch (error) {
      console.error('❌ Error creating time-based index track:', error);
    }
  }

  private createTimeBasedDataTrack(trackInfo: ITimeTrack, trackIndex: number): void {
    try {
      console.log(`🎯 Creating time-based data track: ${trackInfo.trackName}`);

      const logTrack = this.wellLogWidget.addTrack(TrackType.LinearTrack);
      logTrack.setName(trackInfo.trackTitle);
      logTrack.setWidth(100);

      // Create curves for this track
      this.createTimeBasedCurves(logTrack, trackInfo, trackIndex);

      console.log(`✅ Time-based data track created: ${trackInfo.trackName}`);

    } catch (error) {
      console.error(`❌ Error creating time-based data track ${trackInfo.trackName}:`, error);
    }
  }

  /**
   * Creates curves for a time-based track following GeoToolkit standards
   */
  private createTimeBasedCurves(track: LogTrack, trackInfo: ITimeTrack, trackIndex: number): void {
    trackInfo.curves.forEach((curveInfo, curveIndex) => {
      try {
        if (!curveInfo.data || curveInfo.data.length === 0) {
          console.warn(`⚠️ Skipping curve ${curveInfo.mnemonicId} - no data`);
          return;
        }

        console.log(`📈 Creating time-based curve: ${curveInfo.mnemonicId}`);

        // Use the indexCurveTime for time-based index data if available
        let indexData: number[];
        if (this.indexCurveTime.length > 0 && this.indexCurveTime.length === curveInfo.data.length) {
          // Use actual time data from index curve
          indexData = this.indexCurveTime.map(date => date.getTime());
        } else {
          // Generate time-based index data (timestamps)
          indexData = this.generateTimeIndexData(curveInfo.data.length);
        }

        // Create GeoLogData
        const geoLogData = new GeoLogData(curveInfo.mnemonic);
        geoLogData.setValues(indexData, curveInfo.data);

        // Create LogCurve
        const curve = new LogCurve(geoLogData);
        curve.setLineStyle({
          color: this.timeBasedThemeService.getCurveColor(trackIndex + curveIndex),
          width: 2,
        });
        curve.setName(curveInfo.mnemonic);

        // Set normalization limits if not auto scale
        if (!curveInfo.autoScale && curveInfo.min !== undefined && curveInfo.max !== undefined) {
          curve.setNormalizationLimits(curveInfo.min, curveInfo.max);
        }

        track.addChild(curve);
        console.log(`✅ Time-based curve created: ${curveInfo.mnemonicId}`);

      } catch (error) {
        console.error(`❌ Error creating time-based curve ${curveInfo.mnemonicId}:`, error);
      }
    });
  }

  /**
   * Generates time-based index data for curves
   */
  private generateTimeIndexData(length: number): number[] {
    const now = Date.now();
    const interval = 60000; // 1 minute intervals
    return Array.from({ length }, (_, i) => now - (length - i - 1) * interval);
  }

  private async loadTimeBasedData(): Promise<void> {
    console.log('🔄 Loading time-based data...');
    this.showLoading = true;

    try {
      if (!this.wellboreObjects || this.wellboreObjects.length === 0) {
        console.warn('⚠️ No wellbore objects available for time-based data loading');
        return;
      }

      // Load data for each wellbore object
      for (let i = 0; i < this.wellboreObjects.length; i++) {
        const wellboreObject = this.wellboreObjects[i];
        await this.getLogData(wellboreObject, i, false);
      }

      // Configure widget after data is loaded
      this.configureTimeBasedWidget();

      console.log('✅ Time-based data loaded successfully');

    } catch (error) {
      console.error('❌ Error loading time-based data:', error);
    } finally {
      this.showLoading = false;
      this.cdr.detectChanges();
    }
  }

  private configureTimeBasedWidget(): void {
    try {
      console.log('🔧 Configuring time-based widget...');

      // Set time limits based on loaded data
      if (this.indexCurveTime.length > 0) {
        const startTime = this.indexCurveTime[0].getTime();
        const endTime = this.indexCurveTime[this.indexCurveTime.length - 1].getTime();
        this.wellLogWidget.setVisibleDepthLimits(startTime, endTime);
      }

      // Apply time-based scaling
      this.applyTimeBasedScale(this.selectedScale);

      // Configure crosshair for time-based data
      this.configureTimeBasedCrossHair();

      // Start live polling if enabled
      if (this.isLiveTracking) {
        this.startLivePolling();
      }

      this.wellLogWidget.updateLayout();
      console.log('✅ Time-based widget configured');

    } catch (error) {
      console.error('❌ Error configuring time-based widget:', error);
    }
  }

  private configureTimeBasedCrossHair(): void {
    try {
      console.log('🎯 Configuring time-based crosshair...');
      
      // Note: WellLogWidget doesn't have setCrosshair method
      // Crosshair configuration should be done through the widget's tools
      console.log('✅ Time-based crosshair configuration skipped (method not available)');

    } catch (error) {
      console.error('❌ Error configuring time-based crosshair:', error);
    }
  }

  private applyTimeBasedScale(scale: number): void {
    if (!this.wellLogWidget || this.indexCurveTime.length === 0) return;

    try {
      console.log('📏 Applying time-based scale:', scale);

      if (scale === 0) {
        // Fit to height - show all time data
        const startTime = this.indexCurveTime[0].getTime();
        const endTime = this.indexCurveTime[this.indexCurveTime.length - 1].getTime();
        this.wellLogWidget.setVisibleDepthLimits(startTime, endTime);
        this.wellLogWidget.fitToHeight();
      } else {
        // Set visible time range based on scale (hours)
        const timeRangeMs = scale * 3600000; // Convert hours to milliseconds
        const endTime = this.indexCurveTime[this.indexCurveTime.length - 1].getTime();
        const startTime = endTime - timeRangeMs;
        
        // Add buffer for scrolling
        const buffer = timeRangeMs * 0.5;
        const bufferedStart = Math.max(startTime - buffer, this.indexCurveTime[0].getTime());
        const bufferedEnd = Math.min(endTime + buffer, this.indexCurveTime[this.indexCurveTime.length - 1].getTime());
        
        this.wellLogWidget.setVisibleDepthLimits(bufferedStart, bufferedEnd);
      }

      this.wellLogWidget.updateLayout();
      console.log('✅ Time-based scale applied');

    } catch (error) {
      console.error('❌ Error applying time-based scale:', error);
    }
  }

  // Public methods
  onScaleChange(scale: string | number): void {
    this.selectedScale = Number(scale);
    console.log('🔄 Time scale changed to:', this.selectedScale);
    this.applyTimeBasedScale(this.selectedScale);
    this.scaleChange.emit(this.selectedScale);
  }

  toggleTheme(): void {
    this.isDarkTheme = !this.isDarkTheme;
    console.log('🎨 Time theme toggled to:', this.isDarkTheme ? 'dark' : 'light');
    this.timeBasedThemeService.applyGeoToolkitTheme(this.wellLogWidget, this.isDarkTheme);
    this.themeChange.emit(this.isDarkTheme);
  }

  startLivePolling(): void {
    if (this.livePollingInterval) {
      clearInterval(this.livePollingInterval);
    }

    console.log('🔄 Starting live polling for time-based data...');
    this.isLiveTracking = true;

    // Poll every 30 seconds for live data
    this.livePollingInterval = setInterval(() => {
      this.loadLiveData();
    }, 30000);
  }

  stopLivePolling(): void {
    if (this.livePollingInterval) {
      clearInterval(this.livePollingInterval);
      this.livePollingInterval = null;
      console.log('⏹️ Live polling stopped');
    }
    this.isLiveTracking = false;
  }

  private async loadLiveData(): Promise<void> {
    console.log('🔄 Loading live time-based data...');

    try {
      // Load live data for each wellbore object
      for (let i = 0; i < this.wellboreObjects.length; i++) {
        const wellboreObject = this.wellboreObjects[i];
        if (wellboreObject.isGrowing) {
          await this.getLogData(wellboreObject, i, true);
        }
      }

      // Update widget with new data
      this.wellLogWidget.updateLayout();
      console.log('✅ Live time-based data loaded');

    } catch (error) {
      console.error('❌ Error loading live time-based data:', error);
    }
  }

  // Main data loading method (adapted from your existing getLogData)
  getLogData(
    selectedlogObject: ITimeWellboreObject,
    logIndex: number,
    isLiveData: boolean = false
  ): Promise<void> {
    return new Promise((resolve, reject) => {
      let startval: any;
      let endval: any;
      
      console.log('isLiveData --', isLiveData);
      
      if (!selectedlogObject.isDepth) {
        let mindate = new Date();
        let currDate = new Date();
        let lastRigtime = new Date(selectedlogObject.endIndex);
        
        if (
          (lastRigtime < new Date() &&
            this.listOfTracks[0].curves[0].data.length == 0) ||
          (!isLiveData && this.indexCurveTime[0] <= new Date(selectedlogObject.endIndex))
        ) {
          mindate = lastRigtime;
          mindate.setHours(lastRigtime.getHours() - this.selectedHour);
          this.indexCurveTime = [];
        } else if (this.indexCurveTime[0] <= new Date(selectedlogObject.endIndex)) {
          mindate = new Date(selectedlogObject.endIndex);
          mindate.setSeconds(mindate.getSeconds() + 1);
        }
        
        this.lastselectedDate = currDate;
        startval = this.formatDate(mindate, 'yyyy-MM-ddTHH:mm:ss', 'en', 'GMT') + '.000z';
        endval = this.formatDate(currDate, 'yyyy-MM-ddTHH:mm:ss', 'en', 'GMT') + '.000z';
      }
      
      if ((!startval && startval != 0) || (!endval && endval != 0)) {
        this.showLoading = false;
        this.isLiveTracking = false;
        resolve();
        return;
      }

      let queryParameter: ILogDataQueryParameter = {
        wellUid: selectedlogObject.wellId,
        logUid: selectedlogObject.objectId,
        wellboreUid: selectedlogObject.wellboreId,
        logName: selectedlogObject.objectName,
        indexType: selectedlogObject.indexType,
        indexCurve: selectedlogObject.indexCurve,
        startIndex: startval,
        endIndex: endval,
        isGrowing: selectedlogObject.isGrowing,
        mnemonicList: '',
      };

      console.log('queryParameter ', queryParameter);

      this.timeBasedLogService.getLogData(queryParameter).subscribe(
        (response: any) => {
          this.processLogDataResponse(response, selectedlogObject, logIndex, isLiveData);
          resolve();
        },
        (error) => {
          console.error('❌ Error retrieving time-based log data:', error);
          this.showLoading = false;
          this.isLiveTracking = false;
          reject(error);
        }
      );
    });
  }

  private processLogDataResponse(response: any, selectedlogObject: ITimeWellboreObject, logIndex: number, isLiveData: boolean): void {
    console.log('🔄 Processing log data response using simpler pattern');
    
    // Use the same simple pattern as generate-canvas-tracks
    const logData: LogData = {
      mnemonicList: 'TIME,GR,RT,NPHI,RHOB,ROP,WOB,RPM',
      data: response.logs[0].logData.data
    };
    
    // Parse data for each curve in the track
    this.listOfTracks.forEach(track => {
      track.curves.forEach(curve => {
        this.parseCurveData(logData, curve, false);
                        mnemonicInfo.mnemonicId ==
                        selectedlogObject.indexCurve
                      ) {
                        if (!selectedlogObject.isDepth) {
                          this.indexCurveTime.push(new Date(val));
                        }
                      }
                    }
                  });
              });
            }
          }
        );
      });

    selectedlogObject.objectInfo.forEach((mnemonic, index) => {
      if (mnemonic.mnemonic != selectedlogObject.indexCurve) {
        selectedlogObject.objectInfo[index].min = this.getMinValue(
          mnemonic.data
        );
        selectedlogObject.objectInfo[index].max = this.getMaxValue(
          mnemonic.data
        );
      }
    });

    this.wellboreObjects[logIndex] = selectedlogObject;

    selectedlogObject.objectInfo.forEach((val) => {
      if (
        !selectedlogObject.isDepth &&
        val.mnemonicId.toLowerCase() == 'depth'
      ) {
        this.indexCurveTimeDepthForShowMarker = val.data;
  }
  
  /**
   * Parses curve data following the same pattern as generate-canvas-tracks
   */
  private parseCurveData(logData: LogData, curve: ITimeCurve, decrementPending: boolean = true): void {
    const mnemonics = logData.mnemonicList.split(',');
    const curveIndex = mnemonics.findIndex(m => m.trim() === curve.mnemonicId);
    const timeIndex = mnemonics.findIndex(m => m.trim() === 'TIME');
    
    console.log(`🔍 Parsing ${curve.mnemonicId}:`, {
      availableMnemonics: mnemonics,
      curveIndex,
      timeIndex,
      dataRows: logData.data?.length || 0
    });
    
    if (curveIndex === -1) {
      console.warn('⚠️ Mnemonic not found:', curve.mnemonicId);
      return;
    }

    const times: number[] = [];
    const values: number[] = [];

    logData.data.forEach((dataRow) => {
      const cols = dataRow.split(',');
      if (cols.length > curveIndex && cols[curveIndex]) {
        const value = parseFloat(cols[curveIndex]);
        const time = timeIndex >= 0 ? parseFloat(cols[timeIndex]) : NaN;
        if (!isNaN(value) && !isNaN(time)) {
          times.push(time);
          values.push(value);
        }
      }
    });

    curve.data = values;
    
    // Store time indices for the curve
    if (!this.curveTimeIndices) {
      this.curveTimeIndices = new Map<string, number[]>();
    }
    this.curveTimeIndices.set(curve.mnemonicId, times);

    // Track loaded range
    if (times.length > 0) {
      if (!this.loadedTimeRanges) {
        this.loadedTimeRanges = new Map<string, { min: number, max: number }>();
      }
      this.loadedTimeRanges.set(curve.mnemonicId, {
        min: times[0],
        max: times[times.length - 1],
      });
    }

    console.log('✅ Parsed data for curve:', curve.mnemonicId, values.length, 'points',
      times.length > 0 ? `time range: ${times[0]}-${times[times.length - 1]}` : '');
  }

  private formatDate(date: Date, format: string, locale: string, timezone: string): string {
    // Simple date formatting - you might want to use a library like date-fns or moment
    return date.toISOString();
  }

  private getMinValue(arr: any[]): number {
    if (!arr || arr.length === 0) return 0;
    const validValues = arr.filter(val => val !== null && val !== undefined && !isNaN(val));
    return validValues.length > 0 ? Math.min(...validValues) : 0;
  }

  private getMaxValue(arr: any[]): number {
    if (!arr || arr.length === 0) return 0;
    const validValues = arr.filter(val => val !== null && val !== undefined && !isNaN(val));
    return validValues.length > 0 ? Math.max(...validValues) : 0;
  }

  // Methods referenced in HTML template
  formatDateTimeForInput(date: Date): string {
    if (!date) return '';
    // Format for datetime-local input: YYYY-MM-DDTHH:mm
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    const hours = String(date.getHours()).padStart(2, '0');
    const minutes = String(date.getMinutes()).padStart(2, '0');
    return `${year}-${month}-${day}T${hours}:${minutes}`;
  }

  calculateDuration(): string {
    if (this.indexCurveTime.length < 2) return '0 min';
    
    const startTime = this.indexCurveTime[0].getTime();
    const endTime = this.indexCurveTime[this.indexCurveTime.length - 1].getTime();
    const durationMs = endTime - startTime;
    
    const hours = Math.floor(durationMs / 3600000);
    const minutes = Math.floor((durationMs % 3600000) / 60000);
    
    if (hours > 0) {
      return `${hours}h ${minutes}m`;
    } else {
      return `${minutes} min`;
    }
  }

  calculateDataPointsPerHour(): number {
    if (this.indexCurveTime.length < 2) return 0;
    
    const startTime = this.indexCurveTime[0].getTime();
    const endTime = this.indexCurveTime[this.indexCurveTime.length - 1].getTime();
    const durationHours = (endTime - startTime) / 3600000;
    
    if (durationHours <= 0) return 0;
    return Math.round(this.indexCurveTime.length / durationHours);
  }

  applyCustomTimeRange(startTime: string, endTime: string): void {
    if (!startTime || !endTime) {
      console.warn('⚠️ Invalid time range provided');
      return;
    }

    try {
      const start = new Date(startTime);
      const end = new Date(endTime);
      
      if (start >= end) {
        console.warn('⚠️ Start time must be before end time');
        return;
      }

      console.log('📏 Applying custom time range:', start, 'to', end);
      
      if (this.wellLogWidget) {
        this.wellLogWidget.setVisibleDepthLimits(start.getTime(), end.getTime());
        this.wellLogWidget.updateLayout();
      }
    } catch (error) {
      console.error('❌ Error applying custom time range:', error);
    }
  }

  getCurveColor(trackIndex: number): string {
    return this.timeBasedThemeService.getCurveColor(trackIndex);
  }
}
